{
  "manifest_version": 3,
  "name": "Epoch Converter",
  "version": "1.1",
  "description": "Convert IST and GMT date/time to Unix epoch. Select any epoch on a page for instant conversion.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Epoch Converter"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
